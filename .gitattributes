# Auto detect text files and normalize line endings
* text=auto

# C# source files — always use LF
*.cs text eol=lf

# Godot resource files — always use LF
*.gd text eol=lf
*.tscn text eol=lf
*.tres text eol=lf
*.gdns text eol=lf
*.gdlib text eol=lf

# Project config files — always use LF
*.cfg text eol=lf
*.godot text eol=lf

# Documentation — always use LF
*.md text eol=lf
*.txt text eol=lf

# JSON/XML — always use LF
*.json text eol=lf
*.xml text eol=lf

# Shell scripts — always use LF
*.sh text eol=lf
